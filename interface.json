                                        "grand_ex2.png"
                                    ]
                                }
                            }
                        }
                    }
                }
            ]
        },
        "选择难度": {
            "type": "select",
            "cases": [
                {
                    "name": "100⭐⭐",
                    "pipeline_override": {
                        "冠位戴冠战-等级副本": {
                            "recognition": {
                                "type": "TemplateMatch",
                                "param": {
                                    "template": [
                                        "grand_100++.png"
                                    ]
                                }
                            }
                        }
                    }
                },
                {
                    "name": "100⭐⭐⭐",
                    "pipeline_override": {
                        "冠位戴冠战-等级副本": {
                            "recognition": {
                                "type": "TemplateMatch",
                                "param": {
                                    "template": [
                                        "grand_100+++.png"
                                    ]
                                }
                            }
                        }
                    }
                }
            ]
        },
        "bbc路径": {
            "type": "input", // 用户输入类型
            "label": "复制路径名",
            "description": "形式例如：\"F:\\BBchannel\\启动.cmd\",请勿复制快捷方式路径", // 描述，应支持 文件名、URL、字符串，同时内容支持 markdown，支持国际化
            "inputs": [
                {
                    "name": "bbc路径",
                    "label": "$bbc路径", // 显示名称，支持国际化。优先显示label，未设置时显示name
                    "description": "形式例如：\"F:\\BBchannel\\启动.cmd\",请勿复制快捷方式路径，不用带双引号", // 描述，应支持 文件名、URL、字符串，同时内容支持 markdown，支持国际化
                    "pipeline_type": "string", // 拼接到 pipeline_override 中的类型
                }
            ],
            "pipeline_override": {
                "运行BBC": {
                    "action": {
                        "type": "Command",
                        "param": {
                            "exec": "{bbc路径}"
                        }
                    }
                }
            }
        },
        "内置脚本路径（AUTO-MAS专用）": {
            "type": "input", // 用户输入类型
            "inputs": [
                {
                    "name": "内置脚本路径(AUTO-MAS专用)",
                    "label": "$内置脚本路径(AUTO-MAS专用)", // 显示名称，支持国际化。优先显示label，未设置时显示name
                    "description": "如果使用AUTO-MAS启动，需要在此填写MfaFGO里面run_bbc路径下的runbbe.exe的路径", // 描述，应支持 文件名、URL、字符串，同时内容支持 markdown，支持国际化
                    "pipeline_type": "string", // 拼接到 pipeline_override 中的类型
                }
            ],
            "pipeline_override": {
                "冠位戴冠战-BBC脚本运行": {
                    "action": {
                        "type": "Command",
                        "param": {
                            "exec": "{内置脚本路径(AUTO-MAS专用)}"
                        }
                    }
                }
            }
        }
    },
    "global_option": [ // 💡 v2.3.0 全局选项，参与所有任务的 pipeline override，优先级最低
        "bbc路径",
        "内置脚本路径（AUTO-MAS专用）"
]
}