{
    "启动FGO": {
        "action": {
            "type": "StartApp",
            "param": {
                "package": "com.aniplex.fategrandorder"
            }
        },
        "post_delay": 10000,
        "next": [
            "自动登录"
        ]
    },
    "直到达到主界面": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "main_ui.png"
                ]
            }
        },
        "timeout": 40000,
        "post_delay": 5000,
        "next": [
            "确认抵达主界面流程"
        ]
    },
    "自动登录": {
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "タッチして"
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {}
        },
        "post_delay": 5000,
        "next": [
            "自动登录2"
        ]
    },
    "如果要SKIP": {
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "SKIP"
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {}
        },
        "timeout": 5000,
        "next": [
            "点击是"
        ]
    },
    "点击是": {
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "はい"
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {}
        },
        "timeout": 5000,
        "next": [
            "如果有奖励",
            "确认抵达主界面流程"
        ]
    },
    "如果有奖励": {
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "タッチして"
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {}
        },
        "next": [
            "确认抵达主界面流程"
        ]
    },
    "自动登录2": {
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "Touch Screen"
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {}
        },
        "post_delay": 10000,
        "next": [
            "直到达到主界面"
        ]
    },
    "关闭主界面弹窗": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "close_botton.png"
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {}
        },
        "post_delay": 2000
    },
    "最终确认抵达主界面": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "main_ui.png"
                ]
            }
        },
        "focus": {
            "Node.Recognition.Succeeded": "成功抵达主界面",
            "Node.Recognition.Failed": "未成功抵达主界面，脚本中止"
        }
    },
    "如果要关闭": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "close.png"
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {}
        },
        "timeout": 3000
    },
    "打开游戏": {
        "next": [
            "启动FGO"
        ]
    },
    "确认抵达主界面流程": {
        "next": [
            "[JumpBack]关闭主界面弹窗",
            "如果要SKIP",
            "[JumpBack]如果要关闭",
            "如果有奖励",
            "最终确认抵达主界面"
        ]
    }
}